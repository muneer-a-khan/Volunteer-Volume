# Node dependencies
/node_modules/
.pnp/
.pnp.* 
.yarn/*                 # Ignore all Yarn-related files
!.yarn/patches/         # Track patches
!.yarn/plugins/         # Track plugins
!.yarn/releases/        # Track releases
!.yarn/versions/        # Track versions

# Testing directory and logs
/coverage/              # Ignore code coverage output
npm-debug.log*          # Ignore npm debug logs
yarn-debug.log*         # Ignore yarn debug logs
yarn-error.log*         # Ignore yarn error logs
.pnpm-debug.log*        # Ignore pnpm debug logs

# Next.js build output
/.next/                 # Ignore Next.js build output
/out/                   # Ignore Next.js export output

# Production build
/build/                 # Ignore production build directory

# Miscellaneous
.DS_Store               # macOS Finder metadata
*.pem                   # Ignore private keys and certificates

# Environment files (sensitive data, should not be committed)
.env*                   # Ignore all .env files
.env.local              # Local development environment variables
.env.*.local            # Environment variable files specific to local settings

# Vercel deployment configuration
.vercel/

# TypeScript configuration
*.tsbuildinfo           # TypeScript build info files (only necessary for caching)
next-env.d.ts           # Next.js type declarations (generated by Next.js)
